[{"id":"card_001","front":"What is the time complexity of accessing an array element by index?","back":"O(1) — arrays provide constant-time random access because elements are stored in contiguous memory locations","subject":"Algorithms","topic":"arrays","lastReviewed":"2026-03-15","nextReview":"2026-03-28","easeFactor":2.353734358003357,"interval":13,"repetitions":4},{"id":"card_002","front":"How does the two-pointer technique work?","back":"Place pointers at strategic positions (often both ends) and move them based on comparisons, reducing O(n^2) to O(n)","subject":"Algorithms","topic":"arrays","lastReviewed":"2026-03-24","nextReview":"2026-03-29","easeFactor":2.4887503262248716,"interval":5,"repetitions":0},{"id":"card_003","front":"What is a prefix sum and when is it useful?","back":"An array where each element stores the cumulative sum up to that point. Useful for range sum queries in O(1)","subject":"Algorithms","topic":"arrays","lastReviewed":"2026-03-16","nextReview":"2026-03-17","easeFactor":2.032951876871441,"interval":1,"repetitions":0},{"id":"card_004","front":"Explain the sliding window technique","back":"Maintain a variable-size window over the array, expanding/contracting based on conditions. Avoids recomputing from scratch.","subject":"Algorithms","topic":"arrays","lastReviewed":"2026-03-17","nextReview":"2026-03-24","easeFactor":2.230598079962143,"interval":7,"repetitions":2},{"id":"card_005","front":"What is the difference between an array and a dynamic array?","back":"Arrays have fixed size. Dynamic arrays (like JS Array, ArrayList) auto-resize by allocating a larger array and copying elements.","subject":"Algorithms","topic":"arrays","lastReviewed":"2026-03-20","nextReview":"2026-04-03","easeFactor":2.0450472525059227,"interval":14,"repetitions":3},{"id":"card_006","front":"How does Floyd's cycle detection work?","back":"Use two pointers: slow (1 step) and fast (2 steps). If they meet, there's a cycle. If fast reaches null, no cycle.","subject":"Algorithms","topic":"linked-lists","lastReviewed":"2026-03-19","nextReview":"2026-03-23","easeFactor":2.06148058038368,"interval":4,"repetitions":4},{"id":"card_007","front":"How do you reverse a linked list?","back":"Iteratively: use prev/curr/next pointers. Save next, point curr to prev, advance prev and curr. Return prev as new head.","subject":"Algorithms","topic":"linked-lists","lastReviewed":"2026-03-31","nextReview":"2026-04-11","easeFactor":2.1589477977875315,"interval":11,"repetitions":0},{"id":"card_008","front":"Why use a dummy head node?","back":"Simplifies edge cases at the head. All insertions/deletions use the same logic without special-casing the first node.","subject":"Algorithms","topic":"linked-lists","lastReviewed":"2026-03-29","nextReview":"2026-04-01","easeFactor":2.485439775649087,"interval":3,"repetitions":1},{"id":"card_009","front":"What is the advantage of a doubly linked list?","back":"O(1) deletion given a node reference (no need to find previous). Supports backward traversal.","subject":"Algorithms","topic":"linked-lists","lastReviewed":"2026-03-25","nextReview":"2026-04-08","easeFactor":2.318071487470436,"interval":14,"repetitions":4},{"id":"card_010","front":"Array vs Linked List for insertion at the beginning?","back":"Array: O(n) (shift all). Linked List: O(1) (just update head pointer). Linked lists win for frequent head insertions.","subject":"Algorithms","topic":"linked-lists","lastReviewed":"2026-03-24","nextReview":"2026-04-02","easeFactor":2.0572371629040123,"interval":9,"repetitions":3},{"id":"card_011","front":"What are the three types of depth-first traversal?","back":"Pre-order (root, left, right), In-order (left, root, right), Post-order (left, right, root)","subject":"Algorithms","topic":"trees","lastReviewed":"2026-03-31","nextReview":"2026-04-01","easeFactor":2.0769121766356866,"interval":1,"repetitions":4},{"id":"card_012","front":"What is the BST property?","back":"For every node: all left descendants are smaller, all right descendants are larger","subject":"Algorithms","topic":"trees","lastReviewed":"2026-03-16","nextReview":"2026-03-18","easeFactor":2.4642027113289764,"interval":2,"repetitions":1},{"id":"card_013","front":"What is the height of a balanced BST with n nodes?","back":"O(log n). This is why BST operations like search, insert, delete are O(log n) when balanced.","subject":"Algorithms","topic":"trees","lastReviewed":"2026-03-30","nextReview":"2026-04-05","easeFactor":2.105625230218386,"interval":6,"repetitions":0},{"id":"card_014","front":"How does an AVL tree stay balanced?","back":"After insert/delete, check balance factor (height diff of subtrees). If |balance| > 1, perform rotations to rebalance.","subject":"Algorithms","topic":"trees","lastReviewed":"2026-03-19","nextReview":"2026-03-25","easeFactor":2.291480451623566,"interval":6,"repetitions":2},{"id":"card_015","front":"Level-order traversal uses what data structure?","back":"A queue. Process node, enqueue children, dequeue next. This gives BFS order.","subject":"Algorithms","topic":"trees","lastReviewed":"2026-03-17","nextReview":"2026-03-28","easeFactor":2.367085323976871,"interval":11,"repetitions":4},{"id":"card_016","front":"What is the difference between a binary tree and a BST?","back":"Binary tree: each node has at most 2 children. BST: binary tree WITH the ordering property (left < root < right).","subject":"Algorithms","topic":"trees","lastReviewed":"2026-04-01","nextReview":"2026-04-11","easeFactor":2.178512333961186,"interval":10,"repetitions":4},{"id":"card_017","front":"BFS uses which data structure? DFS?","back":"BFS uses a Queue (FIFO). DFS uses a Stack (LIFO) or recursion.","subject":"Algorithms","topic":"graphs","lastReviewed":"2026-03-20","nextReview":"2026-03-27","easeFactor":2.204564425937126,"interval":7,"repetitions":4},{"id":"card_018","front":"When to use Dijkstra vs BFS?","back":"BFS for unweighted graphs (all edges equal). Dijkstra for weighted graphs (edges have different costs).","subject":"Algorithms","topic":"graphs","lastReviewed":"2026-03-20","nextReview":"2026-03-25","easeFactor":2.321030159768055,"interval":5,"repetitions":4},{"id":"card_019","front":"What is topological sorting?","back":"Linear ordering of vertices where every directed edge goes from earlier to later. Only works on DAGs.","subject":"Algorithms","topic":"graphs","lastReviewed":"2026-03-28","nextReview":"2026-03-31","easeFactor":2.1546886128973437,"interval":3,"repetitions":2},{"id":"card_020","front":"How to detect cycles in a directed graph?","back":"Use DFS with a recursion stack. If you visit a node already in the current path, there's a cycle.","subject":"Algorithms","topic":"graphs","lastReviewed":"2026-03-22","nextReview":"2026-03-24","easeFactor":2.04131618166845,"interval":2,"repetitions":4},{"id":"card_021","front":"What is a strongly connected component?","back":"A maximal set of vertices where every vertex is reachable from every other vertex in the set.","subject":"Algorithms","topic":"graphs","lastReviewed":"2026-03-13","nextReview":"2026-03-21","easeFactor":2.3451441395470627,"interval":8,"repetitions":1},{"id":"card_022","front":"BFS time complexity?","back":"O(V + E) — visits every vertex once and explores every edge once.","subject":"Algorithms","topic":"graphs","lastReviewed":"2026-03-25","nextReview":"2026-04-02","easeFactor":2.3578099846016727,"interval":8,"repetitions":1},{"id":"card_023","front":"What two properties must a problem have for DP?","back":"1. Overlapping subproblems (same subproblems solved repeatedly). 2. Optimal substructure (optimal solution contains optimal subsolutions).","subject":"Algorithms","topic":"dynamic-programming","lastReviewed":"2026-03-21","nextReview":"2026-04-02","easeFactor":2.060594819203556,"interval":12,"repetitions":4},{"id":"card_024","front":"Memoization vs Tabulation?","back":"Memoization: top-down, recursive with caching. Tabulation: bottom-up, iterative, fills a table from base cases up.","subject":"Algorithms","topic":"dynamic-programming","lastReviewed":"2026-03-23","nextReview":"2026-03-27","easeFactor":2.4229078245467015,"interval":4,"repetitions":3},{"id":"card_025","front":"How to optimize 2D DP space to 1D?","back":"If dp[i] only depends on dp[i-1], use a single array. For knapsack: iterate capacity in reverse to avoid overwriting needed values.","subject":"Algorithms","topic":"dynamic-programming","lastReviewed":"2026-03-17","nextReview":"2026-03-23","easeFactor":2.2104173169457004,"interval":6,"repetitions":4},{"id":"card_026","front":"What is the 0/1 Knapsack recurrence?","back":"dp[i][w] = max(dp[i-1][w], dp[i-1][w-weight[i]] + value[i]) — either skip item i or include it.","subject":"Algorithms","topic":"dynamic-programming","lastReviewed":"2026-03-27","nextReview":"2026-04-10","easeFactor":2.375359351843789,"interval":14,"repetitions":4},{"id":"card_027","front":"Explain the LCS (Longest Common Subsequence) DP approach","back":"dp[i][j] = length of LCS of first i chars of s1 and first j chars of s2. If s1[i]==s2[j], dp[i][j]=dp[i-1][j-1]+1. Else max(dp[i-1][j], dp[i][j-1]).","subject":"Algorithms","topic":"dynamic-programming","lastReviewed":"2026-03-17","nextReview":"2026-03-22","easeFactor":2.350747718725251,"interval":5,"repetitions":3},{"id":"card_028","front":"How many unique ways to climb n stairs (1 or 2 steps)?","back":"dp[i] = dp[i-1] + dp[i-2]. Same as Fibonacci. dp[0]=1, dp[1]=1.","subject":"Algorithms","topic":"dynamic-programming","lastReviewed":"2026-03-31","nextReview":"2026-04-07","easeFactor":2.0814375465391977,"interval":7,"repetitions":4},{"id":"card_029","front":"QuickSort: average and worst case?","back":"Average: O(n log n). Worst: O(n^2) when pivot is always min/max (e.g., sorted array with first-element pivot).","subject":"Algorithms","topic":"sorting","lastReviewed":"2026-03-22","nextReview":"2026-03-27","easeFactor":2.230003400124298,"interval":5,"repetitions":1},{"id":"card_030","front":"Which sorts are stable?","back":"MergeSort, InsertionSort, BubbleSort, CountingSort. QuickSort and HeapSort are NOT stable.","subject":"Algorithms","topic":"sorting","lastReviewed":"2026-03-21","nextReview":"2026-03-29","easeFactor":2.285452098949211,"interval":8,"repetitions":1},{"id":"card_031","front":"MergeSort space complexity?","back":"O(n) auxiliary space for the temporary array. This is its main disadvantage vs QuickSort.","subject":"Algorithms","topic":"sorting","lastReviewed":"2026-03-23","nextReview":"2026-03-28","easeFactor":2.434596834338919,"interval":5,"repetitions":4},{"id":"card_032","front":"When is Counting Sort efficient?","back":"When the range of values (k) is small relative to n. Time O(n + k). Terrible when k >> n.","subject":"Algorithms","topic":"sorting","lastReviewed":"2026-03-21","nextReview":"2026-03-22","easeFactor":2.4652154119070264,"interval":1,"repetitions":4},{"id":"card_033","front":"What does \"in-place\" sorting mean?","back":"Uses only O(1) extra space. QuickSort is nearly in-place (O(log n) stack). MergeSort is NOT in-place (O(n)).","subject":"Algorithms","topic":"sorting","lastReviewed":"2026-03-15","nextReview":"2026-03-22","easeFactor":2.4696113712853847,"interval":7,"repetitions":3},{"id":"card_034","front":"HeapSort time and space complexity?","back":"Time: O(n log n) guaranteed. Space: O(1) in-place. Stable: No. Good when you need guaranteed O(n log n) with minimal space.","subject":"Algorithms","topic":"sorting","lastReviewed":"2026-03-20","nextReview":"2026-03-25","easeFactor":2.197565887189552,"interval":5,"repetitions":1},{"id":"card_035","front":"What are the two essential parts of a recursive function?","back":"1. Base case(s) — termination condition(s). 2. Recursive case — the function calls itself with a simpler input.","subject":"Algorithms","topic":"recursion","lastReviewed":"2026-03-20","nextReview":"2026-03-27","easeFactor":2.0596571527836343,"interval":7,"repetitions":1},{"id":"card_036","front":"What is tail recursion?","back":"The recursive call is the LAST operation. Compilers can optimize it to O(1) space (tail call optimization).","subject":"Algorithms","topic":"recursion","lastReviewed":"2026-04-01","nextReview":"2026-04-04","easeFactor":2.0505834342590923,"interval":3,"repetitions":0},{"id":"card_037","front":"How to convert recursion to iteration?","back":"Use an explicit stack to replace the call stack. Push initial state, loop while stack not empty, push new states.","subject":"Algorithms","topic":"recursion","lastReviewed":"2026-03-16","nextReview":"2026-03-24","easeFactor":2.43189123547692,"interval":8,"repetitions":2},{"id":"card_038","front":"What causes stack overflow in recursion?","back":"Too deep recursion (no base case, or base case never reached). Each call adds a frame to the call stack.","subject":"Algorithms","topic":"recursion","lastReviewed":"2026-04-01","nextReview":"2026-04-09","easeFactor":2.2322580788595427,"interval":8,"repetitions":4},{"id":"card_039","front":"When to use recursion vs iteration?","back":"Recursion when the problem is naturally recursive (trees, divide & conquer). Iteration for simple loops or when stack depth is a concern.","subject":"Algorithms","topic":"recursion","lastReviewed":"2026-03-24","nextReview":"2026-03-30","easeFactor":2.410646020727966,"interval":6,"repetitions":2},{"id":"card_040","front":"Average and worst case for hash table lookup?","back":"Average: O(1). Worst: O(n) when all keys hash to the same bucket.","subject":"Algorithms","topic":"hash-tables","lastReviewed":"2026-03-23","nextReview":"2026-03-31","easeFactor":2.0294742552362885,"interval":8,"repetitions":1},{"id":"card_041","front":"What is the load factor of a hash table?","back":"n/k where n = number of entries, k = number of buckets. When it exceeds a threshold (usually 0.75), the table resizes.","subject":"Algorithms","topic":"hash-tables","lastReviewed":"2026-03-21","nextReview":"2026-03-27","easeFactor":2.197148179403044,"interval":6,"repetitions":1},{"id":"card_042","front":"Separate chaining vs open addressing?","back":"Chaining: each bucket holds a list of entries. Open addressing: on collision, probe for the next empty slot (linear, quadratic, or double hashing).","subject":"Algorithms","topic":"hash-tables","lastReviewed":"2026-03-31","nextReview":"2026-04-03","easeFactor":2.485364767873503,"interval":3,"repetitions":4},{"id":"card_043","front":"How to solve Two Sum in one pass?","back":"For each element x, check if (target - x) exists in a hash map. If yes, return indices. If no, store x with its index.","subject":"Algorithms","topic":"hash-tables","lastReviewed":"2026-03-23","nextReview":"2026-04-02","easeFactor":2.250957568011104,"interval":10,"repetitions":4},{"id":"card_044","front":"What makes a good hash function for hash tables?","back":"Fast to compute and distributes keys uniformly across buckets. NOT cryptographic — different goal.","subject":"Algorithms","topic":"hash-tables","lastReviewed":"2026-03-16","nextReview":"2026-03-30","easeFactor":2.368145023934449,"interval":14,"repetitions":1}]